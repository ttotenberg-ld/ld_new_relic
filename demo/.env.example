# LaunchDarkly
# Server-side SDK key for the LD project/environment used by both services.
# If unset, services skip flag evaluation (health traffic still flows).
LD_SDK_KEY=

# Flag key to evaluate on every /checkout and /search request.
LD_FLAG_KEY=demo-rollout

# New Relic
# Ingest license key — used both to authenticate the NR agent (and optionally
# PCG's own NR export). Same key in both places.
NEW_RELIC_LICENSE_KEY=

# NR agent target. Default points at the in-compose TLS terminator (Caddy)
# that forwards to PCG. Override to `collector.newrelic.com` to bypass PCG
# entirely. See ../PCG_FINDINGS.md finding #4 for context.
NEW_RELIC_HOST=pcg-tls

# Where the OTel SDK sends traces. Default assumes PCG's OTLP/HTTP receiver
# is port-forwarded to the host.
OTEL_EXPORTER_OTLP_ENDPOINT=http://host.docker.internal:4318

# Simulator
TARGET_RPS=10

# New Relic Port
NEW_RELIC_PORT=8080